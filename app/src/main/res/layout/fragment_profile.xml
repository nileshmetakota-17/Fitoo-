<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/profileScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Your stats and goals"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/profilePhoto"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:background="@drawable/profile_avatar_ring"
            android:contentDescription="Profile photo"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_ninja" />

        <LinearLayout
            android:id="@+id/photoActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnChangePhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change photo"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnRemovePhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Remove"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profileSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/profile_stat_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/summaryName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Name: -"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/summaryAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Age: -"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/summaryGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Gender: -"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/summaryHeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Height: -"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/summaryWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Weight: -"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/summaryGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Goal: -"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/summaryTargetCalories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Target calories: -"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/summaryTargetProtein"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Target protein: -"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Edit profile"
            android:textAllCaps="false"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/profileEditContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/profileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/profile_stat_card"
                android:hint="Name"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <EditText
                android:id="@+id/profileAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/profile_stat_card"
                android:hint="Age"
                android:inputType="number"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Gender"
                android:textColor="#CCFFFFFF"
                android:textSize="15sp" />

            <Spinner
                android:id="@+id/profileGender"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/profile_stat_card"
                android:popupBackground="#CC111111"
                android:spinnerMode="dropdown" />

            <EditText
                android:id="@+id/profileHeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/profile_stat_card"
                android:hint="Height (cm)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <EditText
                android:id="@+id/profileWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/profile_stat_card"
                android:hint="Weight (kg)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Fitness goal"
                android:textColor="#CCFFFFFF"
                android:textSize="15sp" />

            <Spinner
                android:id="@+id/profileGoal"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/profile_stat_card" />

            <EditText
                android:id="@+id/profileTargetCalories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/profile_stat_card"
                android:hint="Daily calories target (kcal)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <EditText
                android:id="@+id/profileTargetProtein"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/profile_stat_card"
                android:hint="Daily protein target (g)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Save profile"
                android:textAllCaps="false" />
        </LinearLayout>

        <Button
            android:id="@+id/btnDeleteAllData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#8B1A1A"
            android:text="Delete all data"
            android:textAllCaps="false" />

    </LinearLayout>

</ScrollView>
